# Resend - Email delivery
# Get your API key at https://resend.com
# Verify your domain in Resend dashboard to use custom sender
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=contacto@diensten.com.ar
RESEND_TO_EMAIL=tu-email@diensten.com.ar

# Cloudflare Turnstile - Spam protection
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# Site key is public (used in frontend), Secret key is server-only
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxx
